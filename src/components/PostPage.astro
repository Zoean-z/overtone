---
import type { CollectionEntry } from "astro:content";
import { getPostUrlBySlug } from "@utils/url-utils";
import PostCard from "./PostCard.astro";

const { page } = Astro.props;

let delay = 0;
const interval = 50;
---
<section class="mb-4">
    <div class="flex items-end justify-between mb-4 px-1">
        <div>
            <div class="text-[0.72rem] uppercase tracking-[0.24em] text-black/38 dark:text-white/35 mb-2">
                Writing
            </div>
            <h2 class="text-2xl md:text-3xl font-bold tracking-[-0.03em] text-black/90 dark:text-white/90">
                Latest notes
            </h2>
        </div>
    </div>
    <div class="transition flex flex-col rounded-[var(--radius-large)] bg-[var(--card-bg)] py-1 md:py-0 md:bg-transparent md:gap-4 mb-4">
        {page.data.length > 0 ? page.data.map((entry: CollectionEntry<"posts">) => (
            <PostCard
                    entry={entry}
                    title={entry.data.title}
                    tags={entry.data.tags}
                    category={entry.data.category}
                    published={entry.data.published}
                    updated={entry.data.updated}
                    url={getPostUrlBySlug(entry.slug)}
                    image={entry.data.image}
                    description={entry.data.description}
                    draft={entry.data.draft}
                    class:list="onload-animation"
                    style={`animation-delay: calc(var(--content-delay) + ${delay++ * interval}ms);`}
            ></PostCard>
        )) : (
            <div class="card-base px-6 py-6 md:px-8 md:py-7 onload-animation">
                <div class="text-sm uppercase tracking-[0.22em] text-black/42 dark:text-white/36 mb-2">
                    In progress
                </div>
                <div class="text-xl md:text-2xl font-bold tracking-[-0.03em] text-black/90 dark:text-white/90 mb-3">
                    Writing is not live yet.
                </div>
                <p class="text-sm md:text-[0.96rem] leading-7 text-black/58 dark:text-white/58 max-w-[38rem]">
                    The structure is ready for essays, project notes, and technical reflections. Add posts in <code>src/content/posts/</code> when you want the blog to start speaking.
                </p>
            </div>
        )}
    </div>
</section>
