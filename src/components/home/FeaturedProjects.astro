---
import { Icon } from "astro-icon/components";
import { projects } from "../../data/projects";
---
<section class="mb-4 md:mb-6">
	<div class="flex items-end justify-between mb-4 px-1">
		<div>
			<div class="text-[0.72rem] uppercase tracking-[0.24em] text-black/38 dark:text-white/35 mb-2">
				Selected work
			</div>
			<h2 class="text-2xl md:text-3xl font-bold tracking-[-0.03em] text-black/90 dark:text-white/90">
				Projects with a strong internal logic
			</h2>
		</div>
		<a href="/projects/" class="hidden md:inline-flex btn-plain rounded-full h-10 px-4 font-semibold active:scale-95">
			All projects
		</a>
	</div>

	<div class="grid gap-4">
		{projects.map((project, index) => (
			<article
				class="card-base relative overflow-hidden group"
				style={`animation-delay: calc(var(--content-delay) + ${index * 70}ms);`}
			>
				<div class={`absolute inset-y-0 left-0 w-full bg-gradient-to-r ${project.accent} opacity-60 dark:opacity-35 transition group-hover:opacity-80 dark:group-hover:opacity-50`}></div>
				<div class="relative px-6 py-6 md:px-8 md:py-7">
					<div class="flex flex-col gap-6 md:flex-row md:items-end md:justify-between">
						<div class="max-w-[42rem]">
							<div class="text-xs uppercase tracking-[0.22em] text-black/42 dark:text-white/38 mb-2">
								{project.status}
							</div>
							<h3 class="text-2xl md:text-[2rem] font-bold tracking-[-0.03em] text-black/90 dark:text-white/92">
								{project.title}
							</h3>
							<p class="text-base md:text-lg text-black/72 dark:text-white/72 mt-2">
								{project.tagline}
							</p>
							<p class="text-sm md:text-[0.96rem] leading-7 text-black/58 dark:text-white/58 mt-4 max-w-[38rem]">
								{project.description}
							</p>
						</div>
						<div class="md:text-right">
							<a
								href={project.github}
								target="_blank"
								rel="noreferrer"
								class="btn-regular rounded-full h-11 px-5 font-semibold inline-flex gap-2 active:scale-95"
							>
								GitHub
								<Icon name="fa6-solid:arrow-up-right-from-square" class="text-sm" />
							</a>
						</div>
					</div>
					<div class="mt-5 flex flex-wrap gap-2">
						{project.stack.map((item) => (
							<span class="rounded-full bg-white/70 dark:bg-white/5 border border-black/8 dark:border-white/8 px-3 py-1.5 text-xs md:text-sm text-black/62 dark:text-white/58">
								{item}
							</span>
						))}
					</div>
				</div>
			</article>
		))}
	</div>
</section>
