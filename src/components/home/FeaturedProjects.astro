---
import { Icon } from "astro-icon/components";
import { projects } from "../../data/projects";
---

<section class="mb-4 md:mb-6">
	<div class="mb-4 flex items-end justify-between px-1">
		<div>
			<div class="mb-2 text-[0.72rem] uppercase tracking-[0.24em] text-black/38 dark:text-white/35">
				Projects
			</div>
			<h2 class="text-2xl font-bold tracking-[-0.03em] text-black/90 dark:text-white/90 md:text-3xl">
				项目
			</h2>
		</div>
		<a href="/projects/" class="hidden h-10 rounded-full px-4 font-semibold active:scale-95 md:inline-flex md:items-center md:justify-center btn-plain">
			查看全部
		</a>
	</div>

	<div class="grid gap-4">
		{projects.map((project, index) => (
			<article
				class="card-base group relative overflow-hidden onload-animation"
				style={`animation-delay: calc(var(--content-delay) + ${index * 70}ms);`}
			>
				<div class="relative px-6 py-6 md:px-8 md:py-7">
					<div class="flex flex-col gap-5 md:flex-row md:items-start md:justify-between">
						<div class="max-w-[42rem]">
							<div class="mb-2 text-xs uppercase tracking-[0.22em] text-black/42 dark:text-white/38">
								{project.status}
							</div>
							<h3 class="text-2xl font-bold tracking-[-0.03em] text-black/90 dark:text-white/92 md:text-[2rem]">
								{project.title}
							</h3>
							<p class="mt-2 text-base text-black/72 dark:text-white/72 md:text-lg">
								{project.tagline}
							</p>
							<p class="mt-3 text-sm leading-7 text-black/42 dark:text-white/42">
								<span class="mr-2 font-medium text-black/48 dark:text-white/48">标签</span>
								{project.stack.join(" / ")}
							</p>
						</div>
						<div class="flex flex-wrap gap-3 md:justify-end">
							<a
								href={project.github}
								target="_blank"
								rel="noreferrer"
								class="inline-flex h-11 items-center justify-center gap-2 rounded-full bg-[var(--primary)] px-5 text-sm font-semibold text-white transition hover:brightness-110 active:scale-95"
							>
								GitHub
								<Icon name="fa6-solid:arrow-up-right-from-square" class="text-xs" />
							</a>
							{project.demo && (
								<a
									href={project.demo}
									target="_blank"
									rel="noreferrer"
									class="inline-flex h-11 items-center justify-center gap-2 rounded-full bg-[var(--btn-regular-bg)] px-5 text-sm font-semibold text-[var(--primary)] transition hover:bg-[var(--btn-regular-bg-hover)] active:scale-95"
								>
									在线演示
									<Icon name="fa6-solid:play" class="text-xs" />
								</a>
							)}
						</div>
					</div>
				</div>
			</article>
		))}
	</div>
</section>
