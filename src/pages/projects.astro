---
import { Icon } from "astro-icon/components";
import { projects } from "../data/projects";
import MainGridLayout from "../layouts/MainGridLayout.astro";
---

<MainGridLayout title="项目" description="Zoean 的项目展示">
	<div class="mb-4 flex flex-col rounded-[var(--radius-large)] bg-[var(--card-bg)] py-1 transition md:gap-4 md:bg-transparent md:py-0">
		{projects.map((project, index) => (
			<article
				class="card-base relative flex w-full flex-col-reverse overflow-hidden rounded-[var(--radius-large)] onload-animation md:flex-col"
				style={`animation-delay: calc(var(--content-delay) + ${index * 60}ms);`}
			>
				<div class="relative w-full pb-6 pl-6 pr-6 pt-6 md:w-[calc(100%_-_28%_-_12px)] md:pl-9 md:pr-2 md:pt-7">
					<div class="mb-3 text-xs uppercase tracking-[0.22em] text-black/35 dark:text-white/28">
						{project.status}
					</div>

					<h2 class="mb-3 text-3xl font-bold text-90">
						{project.title}
					</h2>

					<p class="mb-4 pr-4 text-lg text-75 transition">
						{project.tagline}
					</p>

					<p class="mb-5 pr-4 leading-8 text-75 transition">
						{project.description}
					</p>

					<div class="mb-5 flex flex-wrap gap-3">
						<a
							href={project.github}
							target="_blank"
							rel="noreferrer"
							class="inline-flex h-11 items-center justify-center gap-2 rounded-full bg-[var(--primary)] px-5 text-sm font-semibold text-white transition hover:brightness-110 active:scale-95"
						>
							GitHub
							<Icon name="fa6-solid:arrow-up-right-from-square" class="text-xs" />
						</a>
						{project.demo && (
							<a
								href={project.demo}
								target="_blank"
								rel="noreferrer"
								class="inline-flex h-11 items-center justify-center gap-2 rounded-full bg-[var(--btn-regular-bg)] px-5 text-sm font-semibold text-[var(--primary)] transition hover:bg-[var(--btn-regular-bg-hover)] active:scale-95"
							>
								在线演示
								<Icon name="fa6-solid:play" class="text-xs" />
							</a>
						)}
					</div>

					<div class="pr-4 text-sm leading-7 text-black/42 dark:text-white/42">
						<span class="mr-2 font-medium text-black/48 dark:text-white/48">标签</span>
						{project.stack.join(" / ")}
					</div>
				</div>

				<a
					href={project.demo || project.github}
					target="_blank"
					rel="noreferrer"
					aria-label={`查看 ${project.title}`}
					class:list={[
						"group",
						"relative mx-4 mt-4 -mb-2 max-h-[22vh] overflow-hidden rounded-xl bg-black/10 active:scale-95 md:absolute md:bottom-3 md:right-3 md:top-3 md:mb-0 md:mx-0 md:mt-0 md:max-h-none md:w-[28%]",
						{ [`bg-gradient-to-br ${project.accent}`]: !project.cover },
					]}
				>
					{project.cover && (
						<img
							src={project.cover}
							alt={`${project.title} cover`}
							class="absolute inset-0 h-full w-full object-cover transition duration-500 group-hover:scale-[1.03]"
						/>
					)}
					<div class="absolute inset-0 bg-[radial-gradient(circle_at_top_left,rgba(255,255,255,0.25),transparent_38%)]"></div>
					<div class="pointer-events-none absolute inset-0 z-10 transition group-hover:bg-black/8 group-active:bg-black/14"></div>
					<div class="absolute bottom-4 right-4 z-20 rounded-full bg-black/40 backdrop-blur-sm">
						<Icon
							name="material-symbols:chevron-right-rounded"
							class="text-5xl text-white opacity-90 transition group-hover:opacity-100"
						></Icon>
					</div>
				</a>
			</article>
		))}
	</div>
</MainGridLayout>
